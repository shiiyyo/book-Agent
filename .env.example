# 复制为 .env 并填写实际值后重启服务
# 调用模型（必填其一，否则会报「未配置调用模型」）
OPENAI_MODEL=openai/grok-4-0709
# 或使用：DEFAULT_MODEL=claude-3-5-sonnet
# 示例：OPENAI_MODEL=openai/grok-4-0709  或  OPENAI_MODEL=claude-3-7-sonnet-20250219

# API 密钥（按所选模型配置对应 key）
OPENAI_API_KEY=
# 若用 Claude：ANTHROPIC_API_KEY=sk-ant-xxx
# 若用豆包：VOLCENGINE_API_KEY=xxx

# 可选：代理或自定义 Base URL（如通过统一网关转发）
# OPENAI_API_BASE=https://your-gateway.com/v1
